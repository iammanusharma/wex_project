<?xml version="1.0" encoding="utf-8"?>
<!-- Solution-level NuGet.Config: only nuget.org, no Windows-specific fallback paths.
     This overrides user-level config inside Docker (Linux) where Windows paths don't exist. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
