{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Api": {
    "Version": "1.0"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "TreasuryApi": {
    "BaseUrl": "https://api.fiscaldata.treasury.gov/services/api/fiscal_service/",
    "ExchangeRateEndpoint": "v1/accounting/od/rates_of_exchange",
    "CacheDurationMinutes": 60,
    "RetryCount": 3,
    "RetryDelaySeconds": 2,
    "TimeoutSeconds": 30
  }
}
