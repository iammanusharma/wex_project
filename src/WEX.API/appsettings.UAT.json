{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=uat-db-host;Port=5432;Database=wex_corporate_uat;Username=#{UAT_DB_USER}#;Password=#{UAT_DB_PASSWORD}#"
  },
  "Cors": {
    "AllowedOrigins": [ "https://uat.wex-payments.example.com" ]
  },
  "TreasuryApi": {
    "TimeoutSeconds": 15
  }
}
